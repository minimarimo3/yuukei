--- !u!114 &2012499986
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2012499984}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 99761653d2b9e264eb9d366fbbc44cc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Daihon.Samples.SampleDaihonHandler
  _scriptText: "## \u306F\u3058\u3081\u3066\u306E\u6328\u62F6\u30A4\u30D9\u30F3\u30C8\r\n\u521D\u671F\u5024\uFF1A\r\n   
    \u540D\u524D\u3092\u6559\u3048\u3066\u3082\u3089\u3063\u305F=\u3044\u3044\u3048\r\n   
    \u30E6\u30FC\u30B6\u30FC\u540D=\u300C\u307B\u3052\u307B\u3052\u304F\u3093\u300D\r\n\r\n###
    \u6700\u521D\u306E\u3042\u3044\u3055\u3064\r\n\u5408\u56F3: \uFF20\u8D77\u52D5\u6642
    \u307E\u305F\u306F\u3000\uFF20\u3042\u308C\r\n\r\n\u300C\uFF1C\u7B11\u9854\uFF1E\u3084\u3063\u307B\u30FC\uFF01\u8D77\u52D5\u3057\u3066\u304F\u308C\u3066\u3042\u308A\u304C\u3068\u3046\uFF01\u300D\r\n\u300C\u4ECA\u65E5\u306F\u4F55\u3057\u3066\u904A\u3076\uFF1F\u300D\r\n\r\n$$
    \u30E6\u30FC\u30B6\u30FC\u306E\u540D\u524D\u3092\u521D\u671F\u8A2D\u5B9A\u3059\u308B\uFF08\u307E\u3060\u6C7A\u307E\u3063\u3066\u3044\u306A\u3044\u5834\u5408\uFF09\r\n\u203B\uFF08\u30E6\u30FC\u30B6\u30FC\u540D
    = \u300C\u300D\uFF09:\r\n    \u300C\u305D\u3046\u3044\u3048\u3070\u3001\u307E\u3060\u540D\u524D\u3092\u805E\u3044\u3066\u306A\u304B\u3063\u305F\u306D\u3002\u306A\u3093\u3066\u547C\u3079\u3070\u3044\u3044\uFF1F\u300D\r\n   
    \uFF1C\u540D\u524D\u5165\u529B\u30C0\u30A4\u30A2\u30ED\u30B0\uFF1E\r\n    \u300C\uFF1C\u30E6\u30FC\u30B6\u30FC\u540D\uFF1E\u3055\u3093\u2026\u2026\u3044\u3044\u540D\u524D\u3060\u306D\uFF01\u300D\r\n   
    \u540D\u524D\u3092\u6559\u3048\u3066\u3082\u3089\u3063\u305F=\u306F\u3044\r\n\u304A\u308F\u308A\r\n\r\n\u203B\uFF08\u540D\u524D\u3092\u6559\u3048\u3066\u3082\u3089\u3063\u305F\uFF09:\r\n   
    \u300C\u6539\u3081\u3066\u3001\u3088\u308D\u3057\u304F\u306D\uFF01\uFF1C\u30E6\u30FC\u30B6\u30FC\u540D\uFF1E\u3055\u3093\uFF01\u300D\r\n\u304A\u308F\u308A"
  _dialogueWaitSeconds: 1.5
  _lipSync: {fileID: 678740292}
